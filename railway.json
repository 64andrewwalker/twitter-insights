{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "server/Dockerfile"
  },
  "deploy": {
    "startCommand": "uvicorn server.app:create_app --host 0.0.0.0 --port 8000 --factory",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 10
  }
}
